# Discord application (Developer Portal -> General Information / Bot)
DISCORD_APP_ID=your_application_id
DISCORD_PUBLIC_KEY=your_public_key
DISCORD_BOT_TOKEN=your_bot_token

# The Discord channel ID your bot posts to
DISCORD_TARGET_CHANNEL_ID=your_channel_id

# Mirror notification target: Slack Incoming Webhook URL OR a Discord channel webhook URL
MIRROR_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Postgres connection string (Neon or Supabase free tier)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Dashboard admin login (throwaway account for reviewers)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Secret used to sign JWTs issued to the React frontend on login
JWT_SECRET=replace_with_a_long_random_string

# The deployed URL of your React frontend (for CORS) — comma-separate if you need more than one
CLIENT_ORIGIN=http://localhost:5173

# Port (most hosts set this automatically, fallback for local dev)
PORT=3000
